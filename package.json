{
  "name": "float-launcher",
  "version": "1.0.0",
  "description": "可配置的悬浮快捷启动台",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:helper",
    "build:helper": "node electron/build-hotkey-recorder.cjs",
    "electron:dev": "npm run build:helper && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.float.launcher",
    "productName": "浮点启动台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/HotkeyRecorder.swift",
      "electron/WindowDropMonitor.swift",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-electron/HotkeyRecorder",
        "to": "HotkeyRecorder"
      },
      {
        "from": "dist-electron/WindowDropMonitor",
        "to": "WindowDropMonitor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/app-icon.icns",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
